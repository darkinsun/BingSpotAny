<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="BingSpotAny.AboutWindow"
        Title="About BingSpotAny"
        Width="350" Height="320"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True">
    
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" Margin="20">
        
        <TextBlock Text="BingSpotAny" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"/>
        
        <TextBlock Text="Version 1.0.0" 
                   FontSize="14" 
                   Foreground="Gray" 
                   HorizontalAlignment="Center"/>
        
        <TextBlock Text="A cross-platform daily wallpaper manager powered by .NET and Avalonia UI." 
                   TextWrapping="Wrap" 
                   TextAlignment="Center" 
                   Margin="0,10,0,10"/>
        
        <Button Content="⭐ View on GitHub"
                Background="Transparent"
                Foreground="#007ACC"
                Cursor="Hand"
                HorizontalAlignment="Center"
                Click="Project_Click"/>

        <Button Content="☕ Support / Donate"
                Background="Transparent"
                Foreground="#28A745"
                Cursor="Hand"
                HorizontalAlignment="Center"
                Click="Donate_Click"
                Margin="0,0,0,10"/>
        
        <TextBlock Text="© 2026" 
                   FontSize="12" 
                   Foreground="Gray" 
                   HorizontalAlignment="Center"/>
        
        <Button Content="Close" 
                Width="100" 
                HorizontalAlignment="Center" 
                HorizontalContentAlignment="Center" 
                Click="Close_Click"/>
    </StackPanel>
</Window>