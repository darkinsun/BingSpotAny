<Window
x:Class="BingSpotAny.MainWindow"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="using:BingSpotAny.ViewModels"
x:DataType="vm:MainWindowViewModel"
Title="BingSpotAny"
Icon="avares://BingSpotAny/Assets/icon.png"
Width="900" Height="540"
WindowStartupLocation="CenterScreen"
Background="{StaticResource ThemeBackgroundBrush}">

    <Grid ColumnDefinitions="*, 280" RowDefinitions="*, Auto" Margin="16">

        <Grid Grid.Row="0" Grid.Column="0" Margin="0, 0, 16, 16">

            <Border CornerRadius="8"
                    ClipToBounds="True"
                    Background="#FFE6E6E6">
                <Image x:Name="WallpaperPreview"
                       Source="{Binding CurrentImage}"
                       Stretch="Uniform" />
            </Border>

            <Border Background="#B3000000"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Padding="12,8"
                    CornerRadius="0,0,8,8">
                <TextBlock Text="{Binding CurrentDescription}"
                           Foreground="White"
                           FontSize="13"
                           FontStyle="Italic"
                           TextWrapping="Wrap" />
            </Border>

        </Grid>

        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="0, 0, 16, 0">
            <Button Content="First" Command="{Binding GoFirst}" Width="70" HorizontalContentAlignment="Center"/>
            <Button Content="Prev"  Command="{Binding GoPrev}" Width="70" HorizontalContentAlignment="Center"/>
            <Button Content="Next"  Command="{Binding GoNext}" Width="70" HorizontalContentAlignment="Center"/>
            <Button Content="Last"  Command="{Binding GoLast}" Width="70" HorizontalContentAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Background="#FFF0F0F0"
                CornerRadius="8"
                Padding="16">

            <Grid>

                <StackPanel Spacing="16" VerticalAlignment="Top">

                    <StackPanel Spacing="8">
                        <TextBlock Text="Provider:" FontWeight="SemiBold" />
                        <ComboBox Name="ComboBox1" SelectedIndex="{Binding SelectedProviderIndex}" HorizontalAlignment="Stretch">
                            <ComboBoxItem>Bing</ComboBoxItem>
                            <ComboBoxItem>SpotLight</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <Separator Height="1" Background="#DDDDDD" Margin="0,4"/>

                    <StackPanel Spacing="8">
                        <Button Name="Button1"
                                Content="Set As Wallpaper"
                                Command="{Binding ApplyWallpaperCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Background="#0078D7"
                                Foreground="White"
                                FontWeight="SemiBold"
                                CornerRadius="4"/>

                        <Button Name="Button2"
                                Content="Add to favourites"
                                Command="{Binding AddToFavouritesCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                CornerRadius="4"/>

                        <Button Name="Button3"
                                Content="Save Image As"
                                Command="{Binding SaveImageAsCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                CornerRadius="4"/>
                    </StackPanel>

                    <Separator Height="1" Background="#DDDDDD" Margin="0,4"/>

                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right">
                    <Button Content="About"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Left"
                            Background="Transparent"
                            Foreground="Gray"
                            Cursor="Hand"
                            BorderThickness="0"
                            Click="About_Click"
                            Margin="10"/>
                    <Button Name="BtnOpenArchive"
                            Click="OpenArchive_Click"
                            Width="40" Height="40"
                            Background="#E0E0E0"
                            CornerRadius="20"
                            ToolTip.Tip="Open Provider Archive Folder">
                        <PathIcon Width="18" Height="18" Foreground="#555555"
                                  Data="M10,4H4C2.89,4 2,4.89 2,6V18C2,19.1 2.89,20 4,20H20C21.1,20 22,19.1 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"/>
                    </Button>

                    <Button Name="BtnOpenFavorites"
                            Click="OpenFavorites_Click"
                            Width="40" Height="40"
                            Background="#E0E0E0"
                            CornerRadius="20"
                            ToolTip.Tip="Open Favorites Folder">
                        <PathIcon Width="18" Height="18" Foreground="#E81123"
                                  Data="M20,6H12L10,4H4C2.9,4 2,4.9 2,6V18C2,19.1 2.9,20 4,20H20C21.1,20 22,19.1 22,18V8C22,6.9 21.1,6 20,6M15.4,16.1L12,19.5L8.6,16.1C7.9,15.4 7.9,14.2 8.6,13.5C9.3,12.8 10.4,12.8 11.1,13.5L12,14.4L12.9,13.5C13.6,12.8 14.7,12.8 15.4,13.5C16.1,14.2 16.1,15.4 15.4,16.1Z"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
     
    </Grid>
</Window>